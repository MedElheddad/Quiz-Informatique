function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

function pickQuestions() {
  return shuffle(ALL_QUESTIONS).slice(0, 30);
}

function Quiz() {
  const [questions, setQuestions] = useState(() => pickQuestions());
  const [current, setCurrent] = useState(0);
  const [selected, setSelected] = useState(null);
  const [answers, setAnswers] = useState([]);
  const [showResult, setShowResult] = useState(false);
  const [confirmed, setConfirmed] = useState(false);

  const q = questions[current];
  const color = topicColors[q.topic];
  const progress = (current / questions.length) * 100;

  const handleSelect = (i) => { if (!confirmed) setSelected(i); };
  const handleConfirm = () => { if (selected !== null) setConfirmed(true); };
  const handleNext = () => {
    const newAnswers = [...answers, { question: current, chosen: selected, correct: q.ans }];
    setAnswers(newAnswers);
    if (current + 1 >= questions.length) { setShowResult(true); }
    else { setCurrent(current + 1); setSelected(null); setConfirmed(false); }
  };

  const restart = () => {
    setQuestions(pickQuestions());
    setCurrent(0); setSelected(null); setAnswers([]); setShowResult(false); setConfirmed(false);
  };

  const score = answers.filter(a => a.chosen === a.correct).length;
  const getGrade = (s) => {
    const pct = (s / questions.length) * 100;
    if (pct >= 90) return { label:"Excellent! 🏆", color:"#10B981" };
    if (pct >= 75) return { label:"Très bien! 🎉", color:"#3B82F6" };
    if (pct >= 60) return { label:"Bien 👍", color:"#F59E0B" };
    if (pct >= 50) return { label:"Passable 😐", color:"#F97316" };
    return { label:"À revoir 📚", color:"#EF4444" };
  };

