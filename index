    const qs = questions.filter(q => q.topic === topic);
    const correct = answers.filter((a, i) => questions[i] && questions[i].topic === topic && a.chosen === a.correct).length;
    return { topic, correct, total: qs.length };
  }).filter(t => t.total > 0);

  const Footer = () => (
    <div style={{textAlign:"center",marginTop:"32px",padding:"16px",borderTop:"1px solid rgba(255,255,255,0.1)"}}>
      <span style={{color:"rgba(255,255,255,0.3)",fontSize:"13px",letterSpacing:"1px"}}>
        Créé par <span style={{color:"rgba(255,255,255,0.6)",fontWeight:"700"}}>ELHEDDAD Mohammed</span>
      </span>
    </div>
  );

  if (showResult) {
    const grade = getGrade(score);
    return (
      <div style={{minHeight:"100vh",display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",fontFamily:"'Segoe UI',sans-serif",padding:"20px"}}>
        <div style={{background:"rgba(255,255,255,0.05)",backdropFilter:"blur(20px)",borderRadius:"24px",padding:"40px",maxWidth:"600px",width:"100%",border:"1px solid rgba(255,255,255,0.1)",boxShadow:"0 25px 60px rgba(0,0,0,0.5)"}}>
          <div style={{textAlign:"center",marginBottom:"32px"}}>
            <div style={{fontSize:"64px",marginBottom:"12px"}}>🎯</div>
            <h1 style={{color:"#fff",fontSize:"28px",fontWeight:"800",margin:"0 0 8px"}}>Résultats</h1>
            <div style={{fontSize:"56px",fontWeight:"900",color:grade.color,margin:"12px 0"}}>{score}<span style={{fontSize:"28px",color:"rgba(255,255,255,0.5)"}}>/{questions.length}</span></div>
            <div style={{display:"inline-block",background:grade.color+"22",border:`2px solid ${grade.color}`,color:grade.color,borderRadius:"100px",padding:"8px 24px",fontWeight:"700",fontSize:"18px"}}>{grade.label}</div>
            <div style={{color:"rgba(255,255,255,0.5)",marginTop:"8px",fontSize:"15px"}}>{Math.round((score/questions.length)*100)}% de bonnes réponses</div>
          </div>
          <div style={{marginBottom:"28px"}}>
            <h3 style={{color:"rgba(255,255,255,0.7)",fontSize:"14px",fontWeight:"600",textTransform:"uppercase",letterSpacing:"2px",marginBottom:"16px"}}>Par thème</h3>
            {topicStats.map(({topic,correct,total}) => (
              <div key={topic} style={{marginBottom:"12px"}}>
                <div style={{display:"flex",justifyContent:"space-between",marginBottom:"6px"}}>
                  <span style={{color:"#fff",fontSize:"14px"}}>{topicIcons[topic]} {topic}</span>
                  <span style={{color:topicColors[topic],fontWeight:"700",fontSize:"14px"}}>{correct}/{total}</span>
                </div>
                <div style={{background:"rgba(255,255,255,0.1)",borderRadius:"100px",height:"6px"}}>
                  <div style={{background:topicColors[topic],borderRadius:"100px",height:"100%",width:`${(correct/total)*100}%`}}/>
                </div>
              </div>
            ))}
          </div>
          <button onClick={restart} style={{width:"100%",padding:"14px",background:"linear-gradient(90deg,#6366f1,#8b5cf6)",border:"none",borderRadius:"12px",color:"#fff",fontSize:"16px",fontWeight:"700",cursor:"pointer"}}>
            🔁 Nouvelle série de questions
          </button>
          <Footer />
        </div>
      </div>
    );
  }

  return (
    <div style={{minHeight:"100vh",display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",fontFamily:"'Segoe UI',sans-serif",padding:"20px"}}>
      <div style={{maxWidth:"680px",width:"100%"}}>
        <div style={{marginBottom:"20px"}}>
          <div style={{display:"flex",justifyContent:"space-between",color:"rgba(255,255,255,0.5)",fontSize:"13px",marginBottom:"8px"}}>
            <span>Question {current+1} / {questions.length}</span>
            <span style={{color:"rgba(255,255,255,0.3)",fontSize:"12px"}}>🎲 {ALL_QUESTIONS.length} questions dans la banque</span>
          </div>
          <div style={{background:"rgba(255,255,255,0.1)",borderRadius:"100px",height:"6px"}}>
            <div style={{background:color,borderRadius:"100px",height:"100%",width:`${progress}%`,transition:"width 0.5s ease"}}/>
          </div>
        </div>
        <div style={{background:"rgba(255,255,255,0.05)",backdropFilter:"blur(20px)",borderRadius:"24px",overflow:"hidden",border:"1px solid rgba(255,255,255,0.1)",boxShadow:"0 25px 60px rgba(0,0,0,0.5)"}}>
          <div style={{background:color+"22",borderBottom:`3px solid ${color}`,padding:"12px 28px",display:"flex",alignItems:"center",gap:"8px"}}>
            <span style={{fontSize:"18px"}}>{topicIcons[q.topic]}</span>
            <span style={{color:color,fontWeight:"700",fontSize:"13px",textTransform:"uppercase",letterSpacing:"1.5px"}}>{q.topic}</span>
          </div>
          <div style={{padding:"32px 28px"}}>
            <h2 style={{color:"#fff",fontSize:"20px",fontWeight:"700",lineHeight:"1.5",marginBottom:"28px"}}>{q.q}</h2>
            <div style={{display:"flex",flexDirection:"column",gap:"12px",marginBottom:"28px"}}>
              {q.opts.map((opt,i) => {
                let bg="rgba(255,255,255,0.05)",border="1px solid rgba(255,255,255,0.1)",textColor="rgba(255,255,255,0.85)";
                if(confirmed){
                  if(i===q.ans){bg="#10B98122";border="2px solid #10B981";textColor="#10B981";}
                  else if(i===selected&&i!==q.ans){bg="#EF444422";border="2px solid #EF4444";textColor="#EF4444";}
                } else if(selected===i){bg=color+"33";border=`2px solid ${color}`;textColor="#fff";}
                return (
                  <button key={i} onClick={()=>handleSelect(i)} style={{background:bg,border,borderRadius:"12px",padding:"14px 18px",color:textColor,fontSize:"15px",textAlign:"left",cursor:confirmed?"default":"pointer",transition:"all 0.2s",display:"flex",alignItems:"center",gap:"12px",width:"100%"}}>
                    <span style={{width:"28px",height:"28px",borderRadius:"50%",background:"rgba(255,255,255,0.1)",display:"flex",alignItems:"center",justifyContent:"center",fontWeight:"700",fontSize:"13px",flexShrink:0}}>
                      {confirmed&&i===q.ans?"✓":confirmed&&i===selected&&i!==q.ans?"✗":String.fromCharCode(65+i)}
                    </span>
                    {opt}
                  </button>
                );
              })}
            </div>
            {!confirmed
              ? <button onClick={handleConfirm} disabled={selected===null} style={{width:"100%",padding:"14px",background:selected!==null?`linear-gradient(90deg,${color},${color}cc)`:"rgba(255,255,255,0.1)",border:"none",borderRadius:"12px",color:selected!==null?"#fff":"rgba(255,255,255,0.3)",fontSize:"16px",fontWeight:"700",cursor:selected!==null?"pointer":"not-allowed"}}>
                  Valider ma réponse
                </button>
              : <button onClick={handleNext} style={{width:"100%",padding:"14px",background:"linear-gradient(90deg,#6366f1,#8b5cf6)",border:"none",borderRadius:"12px",color:"#fff",fontSize:"16px",fontWeight:"700",cursor:"pointer"}}>
                  {current+1>=questions.length?"Voir mes résultats 🎯":"Question suivante →"}
                </button>
            }
          </div>
        </div>
        <Footer />
      </div>
    </div>
  );
}

